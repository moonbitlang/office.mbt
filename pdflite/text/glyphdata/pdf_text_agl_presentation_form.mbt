///|
fn pdf_text_codepoint_of_presentation_form_glyphname(name : String) -> Int? {
  match name {
    "/anglebracketleftvertical" => Some(0xFE3F)
    "/anglebracketrightvertical" => Some(0xFE40)
    "/asterisksmall" => Some(0xFE61)
    "/atsmall" => Some(0xFE6B)
    "/blacklenticularbracketleftvertical" => Some(0xFE3B)
    "/blacklenticularbracketrightvertical" => Some(0xFE3C)
    "/braceleftsmall" => Some(0xFE5B)
    "/braceleftvertical" => Some(0xFE37)
    "/bracerightsmall" => Some(0xFE5C)
    "/bracerightvertical" => Some(0xFE38)
    "/colonsmall" => Some(0xFE55)
    "/commasmall" => Some(0xFE50)
    "/cornerbracketleftvertical" => Some(0xFE41)
    "/cornerbracketrightvertical" => Some(0xFE42)
    "/dblanglebracketleftvertical" => Some(0xFE3D)
    "/dblanglebracketrightvertical" => Some(0xFE3E)
    "/dollarsmall" => Some(0xFE69)
    "/emdashvertical" => Some(0xFE31)
    "/endashvertical" => Some(0xFE32)
    "/equalsmall" => Some(0xFE66)
    "/greatersmall" => Some(0xFE65)
    "/hyphensmall" => Some(0xFE63)
    "/lesssmall" => Some(0xFE64)
    "/lowlinecenterline" => Some(0xFE4E)
    "/lowlinedashed" => Some(0xFE4D)
    "/numbersignsmall" => Some(0xFE5F)
    "/overlinecenterline" => Some(0xFE4A)
    "/overlinedashed" => Some(0xFE49)
    "/overlinedblwavy" => Some(0xFE4C)
    "/overlinewavy" => Some(0xFE4B)
    "/parenleftsmall" => Some(0xFE59)
    "/parenleftvertical" => Some(0xFE35)
    "/parenrightsmall" => Some(0xFE5A)
    "/parenrightvertical" => Some(0xFE36)
    "/percentsmall" => Some(0xFE6A)
    "/periodsmall" => Some(0xFE52)
    "/plussmall" => Some(0xFE62)
    "/semicolonsmall" => Some(0xFE54)
    "/tortoiseshellbracketleftsmall" => Some(0xFE5D)
    "/tortoiseshellbracketleftvertical" => Some(0xFE39)
    "/tortoiseshellbracketrightsmall" => Some(0xFE5E)
    "/tortoiseshellbracketrightvertical" => Some(0xFE3A)
    "/twodotleadervertical" => Some(0xFE30)
    "/underscorevertical" => Some(0xFE33)
    "/underscorewavy" => Some(0xFE4F)
    "/wavyunderscorevertical" => Some(0xFE34)
    "/whitecornerbracketleftvertical" => Some(0xFE43)
    "/whitecornerbracketrightvertical" => Some(0xFE44)
    _ => None
  }
}
