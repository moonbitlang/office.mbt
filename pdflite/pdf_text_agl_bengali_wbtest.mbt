    ("/gabengali", 0x0997),
    ("/ghabengali", 0x0998),
    ("/habengali", 0x09B9),
    ("/ibengali", 0x0987),
    ("/iibengali", 0x0988),
    ("/iivowelsignbengali", 0x09C0),
    ("/issharbengali", 0x09FA),
    ("/ivowelsignbengali", 0x09BF),
    ("/jabengali", 0x099C),
    ("/jhabengali", 0x099D),
    ("/kabengali", 0x0995),
    ("/khabengali", 0x0996),
    ("/labengali", 0x09B2),
    ("/llvocalicbengali", 0x09E1),
    ("/llvocalicvowelsignbengali", 0x09E3),
    ("/lvocalicbengali", 0x098C),
    ("/lvocalicvowelsignbengali", 0x09E2),
    ("/mabengali", 0x09AE),
    ("/nabengali", 0x09A8),
    ("/ngabengali", 0x0999),
    ("/ninebengali", 0x09EF),
    ("/nnabengali", 0x09A3),
    ("/nuktabengali", 0x09BC),
    ("/nyabengali", 0x099E),
    ("/obengali", 0x0993),
    ("/onebengali", 0x09E7),
