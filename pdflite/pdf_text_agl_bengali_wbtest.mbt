    ("/ovowelsignbengali", 0x09CB),
    ("/pabengali", 0x09AA),
    ("/phabengali", 0x09AB),
    ("/rabengali", 0x09B0),
    ("/ralowerdiagonalbengali", 0x09F1),
    ("/ramiddlediagonalbengali", 0x09F0),
    ("/rhabengali", 0x09DD),
    ("/rrabengali", 0x09DC),
    ("/rrvocalicbengali", 0x09E0),
    ("/rrvocalicvowelsignbengali", 0x09C4),
    ("/rupeemarkbengali", 0x09F2),
