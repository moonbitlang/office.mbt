    ("/aabengali", 0x0986),
    ("/aavowelsignbengali", 0x09BE),
    ("/abengali", 0x0985),
    ("/aibengali", 0x0990),
    ("/aivowelsignbengali", 0x09C8),
    ("/anusvarabengali", 0x0982),
    ("/aubengali", 0x0994),
    ("/aulengthmarkbengali", 0x09D7),
    ("/auvowelsignbengali", 0x09CC),
    ("/babengali", 0x09AC),
    ("/bhabengali", 0x09AD),
    ("/cabengali", 0x099A),
    ("/candrabindubengali", 0x0981),
    ("/chabengali", 0x099B),
    ("/dabengali", 0x09A6),
    ("/ddabengali", 0x09A1),
    ("/ddhabengali", 0x09A2),
    ("/denominatorminusonenumeratorbengali", 0x09F8),
    ("/dhabengali", 0x09A7),
    ("/ebengali", 0x098F),
    ("/eightbengali", 0x09EE),
