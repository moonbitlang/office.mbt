    ("/rvocalicbengali", 0x098B),
    ("/rvocalicvowelsignbengali", 0x09C3),
    ("/sabengali", 0x09B8),
    ("/sevenbengali", 0x09ED),
    ("/shabengali", 0x09B6),
    ("/sixbengali", 0x09EC),
    ("/sixteencurrencydenominatorbengali", 0x09F9),
    ("/ssabengali", 0x09B7),
