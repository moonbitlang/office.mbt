///|
test "PdfTextExtractor decodes CJK compatibility square AGL glyph names" {
  let entries : Array[(String, Int)] = [
    ("/GBsquare", 0x3387),
    ("/HPsquare", 0x33CB),
    ("/Hzsquare", 0x3390),
    ("/KBsquare", 0x3385),
    ("/KKsquare", 0x33CD),
    ("/MBsquare", 0x3386),
    ("/aarusquare", 0x3303),
    ("/amsquare", 0x33C2),
    ("/apaatosquare", 0x3300),
    ("/birusquare", 0x3331),
    ("/bqsquare", 0x33C3),
    ("/calsquare", 0x3388),
    ("/cdsquare", 0x33C5),
    ("/cmcubedsquare", 0x33A4),
    ("/cmsquaredsquare", 0x33A0),
    ("/corporationsquare", 0x337F),
    ("/cosquare", 0x33C7),
    ("/coverkgsquare", 0x33C6),
    ("/dbsquare", 0x33C8),
    ("/dlsquare", 0x3397),
    ("/dorusquare", 0x3326),
    ("/fmsquare", 0x3399),
    ("/ghzsquare", 0x3393),
    ("/gpasquare", 0x33AC),
    ("/guramusquare", 0x3318),
    ("/gysquare", 0x33C9),
    ("/haitusquare", 0x332A),
    ("/hasquare", 0x33CA),
    ("/heiseierasquare", 0x337B),
    ("/hekutaarusquare", 0x3336),
    ("/herutusquare", 0x3339),
    ("/hoonsquare", 0x3342),
    ("/huiitosquare", 0x3333),
    ("/intisquare", 0x3305),
    ("/karoriisquare", 0x330D),
    ("/kasquare", 0x3384),
    ("/kcalsquare", 0x3389),
    ("/khzsquare", 0x3391),
    ("/kiroguramusquare", 0x3315),
    ("/kiromeetorusquare", 0x3316),
    ("/kirosquare", 0x3314),
    ("/klsquare", 0x3398),
    ("/kmcubedsquare", 0x33A6),
    ("/kmsquaredsquare", 0x33A2),
    ("/kohmsquare", 0x33C0),
    ("/kooposquare", 0x331E),
    ("/kpasquare", 0x33AA),
    ("/ktsquare", 0x33CF),
    ("/kvsquare", 0x33B8),
    ("/kwsquare", 0x33BE),
    ("/lmsquare", 0x33D0),
    ("/lxsquare", 0x33D3),
    ("/mansyonsquare", 0x3347),
    ("/masquare", 0x3383),
    ("/mbsquare", 0x33D4),
    ("/mcubedsquare", 0x33A5),
    ("/meetorusquare", 0x334D),
    ("/meizierasquare", 0x337E),
    ("/mhzsquare", 0x3392),
    ("/miribaarusquare", 0x334A),
    ("/mirisquare", 0x3349),
    ("/mlsquare", 0x3396),
    ("/mmcubedsquare", 0x33A3),
    ("/mmsquaredsquare", 0x339F),
    ("/mohmsquare", 0x33C1),
    ("/molsquare", 0x33D6),
    ("/moverssquare", 0x33A7),
    ("/moverssquaredsquare", 0x33A8),
    ("/mpasquare", 0x33AB),
    ("/mssquare", 0x33B3),
    ("/muasquare", 0x3382),
    ("/mufsquare", 0x338C),
    ("/mugsquare", 0x338D),
    ("/mulsquare", 0x3395),
    ("/mumsquare", 0x339B),
    ("/mussquare", 0x33B2),
    ("/muvsquare", 0x33B6),
    ("/muwsquare", 0x33BC),
    ("/mvmegasquare", 0x33B9),
    ("/mvsquare", 0x33B7),
    ("/mwmegasquare", 0x33BF),
    ("/mwsquare", 0x33BD),
    ("/nasquare", 0x3381),
    ("/nfsquare", 0x338B),
    ("/nmsquare", 0x339A),
    ("/nssquare", 0x33B1),
    ("/nvsquare", 0x33B5),
    ("/nwsquare", 0x33BB),
    ("/paampssquare", 0x3380),
    ("/paasentosquare", 0x332B),
    ("/pasquare", 0x33A9),
    ("/peezisquare", 0x333B),
    ("/pfsquare", 0x338A),
    ("/pmsquare", 0x33D8),
    ("/pssquare", 0x33B0),
    ("/pvsquare", 0x33B4),
    ("/pwsquare", 0x33BA),
    ("/radoverssquare", 0x33AE),
    ("/radoverssquaredsquare", 0x33AF),
    ("/radsquare", 0x33AD),
    ("/rittorusquare", 0x3351),
    ("/sentisquare", 0x3322),
    ("/sentosquare", 0x3323),
    ("/squarecc", 0x33C4),
    ("/squarecm", 0x339D),
    ("/squarekg", 0x338F),
    ("/squarekm", 0x339E),
    ("/squarekmcapital", 0x33CE),
    ("/squareln", 0x33D1),
    ("/squarelog", 0x33D2),
    ("/squaremg", 0x338E),
    ("/squaremil", 0x33D5),
    ("/squaremm", 0x339C),
    ("/squaremsquared", 0x33A1),
    ("/srsquare", 0x33DB),
    ("/svsquare", 0x33DC),
    ("/syouwaerasquare", 0x337C),
    ("/taisyouerasquare", 0x337D),
    ("/thzsquare", 0x3394),
    ("/tonsquare", 0x3327),
    ("/wattosquare", 0x3357),
    ("/wbsquare", 0x33DD),
    ("/yaadosquare", 0x334E),
  ]
  let differences : Array[@pdflite.PdfEncodingDifference] = []
  let text_codes : Array[Int] = []
  let expected_codepoints : Array[Int] = []
  for index in 0..<entries.length() {
    let entry = entries[index]
    let code = index + 1
    differences.push(text_difference_for_test(entry.0, code))
    text_codes.push(code)
    expected_codepoints.push(entry.1)
  }
  let standard_font : @pdflite.PdfFont = PdfFontStandard(
    text_standard_font_data_for_test(
      PdfHelvetica,
      PdfCustomEncoding(PdfStandardEncoding, differences),
    ),
  )
  let extractor = standard_font.text_extractor()
  @test.assert_eq(
    try! extractor.codepoints_of_text(text_bytes_for_test(text_codes)),
    expected_codepoints,
  )
  @test.assert_eq(extractor.charcode_of_codepoint(0x3387), Some(1))
  @test.assert_eq(extractor.charcode_of_codepoint(0x3397), Some(20))
  @test.assert_eq(extractor.charcode_of_codepoint(0x33BE), Some(50))
  @test.assert_eq(extractor.charcode_of_codepoint(0x339B), Some(75))
  @test.assert_eq(extractor.charcode_of_codepoint(0x33AD), Some(100))
  @test.assert_eq(extractor.charcode_of_codepoint(0x334E), Some(123))
}
