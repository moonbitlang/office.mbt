///|
fn pdf_unicode_data_source_base64() -> String {
  let mut output = ""
  for chunk in pdf_unicode_data_source_base64_chunks {
    output = output + chunk
  }
  output
}

///|
/// Return cpdf's compressed UnicodeData source bytes.
pub fn pdf_unicode_data_source() -> PdfBytes raise PdfError {
  @base64.decode(pdf_unicode_data_source_base64()) catch {
    _ => raise SoftError("malformed UnicodeData source")
  }
}
