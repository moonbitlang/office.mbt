    ("/ushortcyrillic", 0x045E),
    ("/ustraightcyrillic", 0x04AF),
    ("/ustraightstrokecyrillic", 0x04B1),
    ("/vecyrillic", 0x0432),
    ("/yatcyrillic", 0x0463),
    ("/yericyrillic", 0x044B),
    ("/yerudieresiscyrillic", 0x04F9),
    ("/yicyrillic", 0x0457),
    ("/yusbigcyrillic", 0x046B),
    ("/yusbigiotifiedcyrillic", 0x046D),
    ("/yuslittlecyrillic", 0x0467),
    ("/yuslittleiotifiedcyrillic", 0x0469),
    ("/zecyrillic", 0x0437),
    ("/zedescendercyrillic", 0x0499),
    ("/zedieresiscyrillic", 0x04DF),
    ("/zhebrevecyrillic", 0x04C2),
    ("/zhecyrillic", 0x0436),
    ("/zhedescendercyrillic", 0x0497),
    ("/zhedieresiscyrillic", 0x04DD),
  ]
  let differences : Array[@pdflite.PdfEncodingDifference] = []
  let text_codes : Array[Int] = []
  let expected_codepoints : Array[Int] = []
  for index in 0..<entries.length() {
    let entry = entries[index]
    let code = index + 1
    differences.push(text_difference_for_test(entry.0, code))
    text_codes.push(code)
    expected_codepoints.push(entry.1)
  }
  let standard_font : @pdflite.PdfFont = PdfFontStandard(
    text_standard_font_data_for_test(
      PdfHelvetica,
      PdfCustomEncoding(PdfStandardEncoding, differences),
    ),
  )
  let extractor = standard_font.text_extractor()
  @test.assert_eq(
    try! extractor.codepoints_of_text(text_bytes_for_test(text_codes)[:]),
    expected_codepoints,
  )
  @test.assert_eq(extractor.charcode_of_codepoint(0x04D0), Some(1))
  @test.assert_eq(extractor.charcode_of_codepoint(0x0410), Some(2))
  @test.assert_eq(extractor.charcode_of_codepoint(0x0474), Some(50))
  @test.assert_eq(extractor.charcode_of_codepoint(0x046A), Some(100))
  @test.assert_eq(extractor.charcode_of_codepoint(0x044A), Some(150))
  @test.assert_eq(extractor.charcode_of_codepoint(0x0483), Some(200))
  @test.assert_eq(extractor.charcode_of_codepoint(0x04DD), Some(226))
}
