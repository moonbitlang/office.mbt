import {
  "moonbitlang/core/test",
} for "test"

import {
  "moonbitlang/core/hashmap",
  "moonbitlang/core/test",
} for "wbtest"

options(
  "native-stub": [
    "pdf_clip_native.c",
    "pdf_random_native.c",
    "pdf_time_native.c",
  ],
  targets: {
    // Files absent from this map build for all backends (moon default). Only the
    // genuinely native-only files (extern "c" stubs and their tests) are listed;
    // the previous ~133 all-target entries were redundant no-ops. See
    // EXECUTION_PLAN.md commit A3.
    "pdf_clip_native.mbt": [ "native" ],
    "pdf_clip_native_test.mbt": [ "native" ],
    "pdf_random_native.mbt": [ "native" ],
    "pdf_random_native_test.mbt": [ "native" ],
    "pdf_random_native_wbtest.mbt": [ "native" ],
    "pdf_strftime_native.mbt": [ "native" ],
    "pdf_strftime_native_test.mbt": [ "native" ],
  },
)
