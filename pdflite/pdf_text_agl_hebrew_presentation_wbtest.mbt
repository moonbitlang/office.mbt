///|
test "private Hebrew presentation-form AGL glyph helper covers table" {
  let entries : Array[(String, Int)] = [
    ("/afii57694", 0xFB2A),
    ("/afii57695", 0xFB2B),
    ("/afii57700", 0xFB4B),
    ("/afii57705", 0xFB1F),
    ("/afii57723", 0xFB35),
    ("/alefdageshhebrew", 0xFB30),
    ("/aleflamedhebrew", 0xFB4F),
    ("/alefpatahhebrew", 0xFB2E),
    ("/alefqamatshebrew", 0xFB2F),
    ("/ayinaltonehebrew", 0xFB20),
    ("/betdagesh", 0xFB31),
    ("/betdageshhebrew", 0xFB31),
    ("/betrafehebrew", 0xFB4C),
    ("/daletdagesh", 0xFB33),
    ("/daletdageshhebrew", 0xFB33),
    ("/doubleyodpatah", 0xFB1F),
    ("/doubleyodpatahhebrew", 0xFB1F),
    ("/finalkafdagesh", 0xFB3A),
    ("/finalkafdageshhebrew", 0xFB3A),
    ("/gimeldagesh", 0xFB32),
    ("/gimeldageshhebrew", 0xFB32),
    ("/hedagesh", 0xFB34),
    ("/hedageshhebrew", 0xFB34),
    ("/kafdagesh", 0xFB3B),
    ("/kafdageshhebrew", 0xFB3B),
    ("/kafrafehebrew", 0xFB4D),
    ("/lameddagesh", 0xFB3C),
    ("/lameddageshhebrew", 0xFB3C),
    ("/memdagesh", 0xFB3E),
    ("/memdageshhebrew", 0xFB3E),
    ("/nundagesh", 0xFB40),
    ("/nundageshhebrew", 0xFB40),
    ("/pedagesh", 0xFB44),
    ("/pedageshhebrew", 0xFB44),
    ("/pefinaldageshhebrew", 0xFB43),
    ("/perafehebrew", 0xFB4E),
    ("/qofdagesh", 0xFB47),
    ("/qofdageshhebrew", 0xFB47),
    ("/reshdageshhebrew", 0xFB48),
    ("/samekhdagesh", 0xFB41),
    ("/samekhdageshhebrew", 0xFB41),
    ("/shindagesh", 0xFB49),
    ("/shindageshhebrew", 0xFB49),
    ("/shindageshshindot", 0xFB2C),
    ("/shindageshshindothebrew", 0xFB2C),
    ("/shindageshsindot", 0xFB2D),
    ("/shindageshsindothebrew", 0xFB2D),
    ("/shinshindot", 0xFB2A),
    ("/shinshindothebrew", 0xFB2A),
    ("/shinsindot", 0xFB2B),
    ("/shinsindothebrew", 0xFB2B),
    ("/tavdages", 0xFB4A),
    ("/tavdagesh", 0xFB4A),
    ("/tavdageshhebrew", 0xFB4A),
    ("/tetdagesh", 0xFB38),
    ("/tetdageshhebrew", 0xFB38),
    ("/tsadidagesh", 0xFB46),
    ("/tsadidageshhebrew", 0xFB46),
    ("/vavdagesh", 0xFB35),
    ("/vavdagesh65", 0xFB35),
    ("/vavdageshhebrew", 0xFB35),
    ("/vavholam", 0xFB4B),
    ("/vavholamhebrew", 0xFB4B),
    ("/yoddagesh", 0xFB39),
    ("/yoddageshhebrew", 0xFB39),
    ("/yodyodpatahhebrew", 0xFB1F),
    ("/zayindagesh", 0xFB36),
    ("/zayindageshhebrew", 0xFB36),
  ]
  for entry in entries {
    @test.assert_eq(
      pdf_text_codepoint_of_hebrew_glyphname(wbtest_text_name(entry.0)),
      Some(entry.1),
    )
  }
  @test.assert_eq(
    pdf_text_codepoint_of_hebrew_glyphname(wbtest_text_name("/not-hebrew-form")),
    None,
  )
}
