///|
fn pdf_standard14_afm_bytes(text : String) -> PdfBytes {
  @ascii.encode(text)
}

///|
fn pdf_standard14_afm_header(
  key : String,
  value : String,
) -> (PdfBytes, PdfBytes) {
  (pdf_standard14_afm_bytes(key), pdf_standard14_afm_bytes(value))
}

