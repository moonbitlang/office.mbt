///|
test "PdfTextExtractor decodes Arabic presentation-form AGL glyph names" {
  let entries : Array[(String, Int)] = [
    ("/ainfinalarabic", 0xFECA),
    ("/aininitialarabic", 0xFECB),
    ("/ainmedialarabic", 0xFECC),
    ("/aleffinalarabic", 0xFE8E),
    ("/alefhamzaabovefinalarabic", 0xFE84),
    ("/alefhamzabelowfinalarabic", 0xFE88),
    ("/alefmaddaabovefinalarabic", 0xFE82),
    ("/alefmaksurafinalarabic", 0xFEF0),
    ("/alefmaksurainitialarabic", 0xFEF3),
    ("/alefmaksuramedialarabic", 0xFEF4),
    ("/behfinalarabic", 0xFE90),
    ("/behinitialarabic", 0xFE91),
    ("/behmedialarabic", 0xFE92),
    ("/behmeeminitialarabic", 0xFC9F),
    ("/behmeemisolatedarabic", 0xFC08),
    ("/behnoonfinalarabic", 0xFC6D),
    ("/dadfinalarabic", 0xFEBE),
    ("/dadinitialarabic", 0xFEBF),
    ("/dadmedialarabic", 0xFEC0),
    ("/dalfinalarabic", 0xFEAA),
    ("/ddalfinalarabic", 0xFB89),
    ("/fehfinalarabic", 0xFED2),
    ("/fehinitialarabic", 0xFED3),
    ("/fehmedialarabic", 0xFED4),
    ("/gaffinalarabic", 0xFB93),
    ("/gafinitialarabic", 0xFB94),
    ("/gafmedialarabic", 0xFB95),
    ("/ghainfinalarabic", 0xFECE),
    ("/ghaininitialarabic", 0xFECF),
    ("/ghainmedialarabic", 0xFED0),
    ("/hahfinalarabic", 0xFEA2),
    ("/hahinitialarabic", 0xFEA3),
    ("/hahmedialarabic", 0xFEA4),
    ("/hehfinalaltonearabic", 0xFBA7),
    ("/hehfinalalttwoarabic", 0xFEEA),
    ("/hehfinalarabic", 0xFEEA),
    ("/hehhamzaabovefinalarabic", 0xFBA5),
    ("/hehhamzaaboveisolatedarabic", 0xFBA4),
    ("/hehinitialaltonearabic", 0xFBA8),
    ("/hehinitialarabic", 0xFEEB),
    ("/hehmedialaltonearabic", 0xFBA9),
    ("/hehmedialarabic", 0xFEEC),
    ("/jeemfinalarabic", 0xFE9E),
    ("/jeeminitialarabic", 0xFE9F),
    ("/jeemmedialarabic", 0xFEA0),
    ("/jehfinalarabic", 0xFB8B),
    ("/kaffinalarabic", 0xFEDA),
    ("/kafinitialarabic", 0xFEDB),
    ("/kafmedialarabic", 0xFEDC),
    ("/khahfinalarabic", 0xFEA6),
    ("/khahinitialarabic", 0xFEA7),
    ("/khahmedialarabic", 0xFEA8),
    ("/lamaleffinalarabic", 0xFEFC),
    ("/lamalefhamzaabovefinalarabic", 0xFEF8),
    ("/lamalefhamzaaboveisolatedarabic", 0xFEF7),
    ("/lamalefhamzabelowfinalarabic", 0xFEFA),
    ("/lamalefhamzabelowisolatedarabic", 0xFEF9),
    ("/lamalefisolatedarabic", 0xFEFB),
    ("/lamalefmaddaabovefinalarabic", 0xFEF6),
    ("/lamalefmaddaaboveisolatedarabic", 0xFEF5),
    ("/lamfinalarabic", 0xFEDE),
    ("/lamhahinitialarabic", 0xFCCA),
    ("/laminitialarabic", 0xFEDF),
    ("/lamjeeminitialarabic", 0xFCC9),
    ("/lamkhahinitialarabic", 0xFCCB),
    ("/lamlamhehisolatedarabic", 0xFDF2),
    ("/lammedialarabic", 0xFEE0),
    ("/lammeemhahinitialarabic", 0xFD88),
    ("/lammeeminitialarabic", 0xFCCC),
    ("/meemfinalarabic", 0xFEE2),
    ("/meeminitialarabic", 0xFEE3),
    ("/meemmedialarabic", 0xFEE4),
    ("/meemmeeminitialarabic", 0xFCD1),
    ("/meemmeemisolatedarabic", 0xFC48),
    ("/noonfinalarabic", 0xFEE6),
    ("/noonghunnafinalarabic", 0xFB9F),
    ("/nooninitialarabic", 0xFEE7),
    ("/noonjeeminitialarabic", 0xFCD2),
    ("/noonjeemisolatedarabic", 0xFC4B),
    ("/noonmedialarabic", 0xFEE8),
    ("/noonmeeminitialarabic", 0xFCD5),
    ("/noonmeemisolatedarabic", 0xFC4E),
    ("/noonnoonfinalarabic", 0xFC8D),
    ("/parenleftaltonearabic", 0xFD3E),
    ("/parenrightaltonearabic", 0xFD3F),
    ("/pehfinalarabic", 0xFB57),
    ("/pehinitialarabic", 0xFB58),
    ("/pehmedialarabic", 0xFB59),
    ("/qaffinalarabic", 0xFED6),
    ("/qafinitialarabic", 0xFED7),
    ("/qafmedialarabic", 0xFED8),
    ("/rehfinalarabic", 0xFEAE),
    ("/rrehfinalarabic", 0xFB8D),
    ("/sadfinalarabic", 0xFEBA),
    ("/sadinitialarabic", 0xFEBB),
    ("/sadmedialarabic", 0xFEBC),
    ("/sallallahoualayhewasallamarabic", 0xFDFA),
    ("/seenfinalarabic", 0xFEB2),
    ("/seeninitialarabic", 0xFEB3),
    ("/seenmedialarabic", 0xFEB4),
    ("/shaddadammaarabic", 0xFC61),
    ("/shaddadammatanarabic", 0xFC5E),
    ("/shaddafathaarabic", 0xFC60),
    ("/shaddakasraarabic", 0xFC62),
    ("/shaddakasratanarabic", 0xFC5F),
    ("/sheenfinalarabic", 0xFEB6),
    ("/sheeninitialarabic", 0xFEB7),
    ("/sheenmedialarabic", 0xFEB8),
    ("/tahfinalarabic", 0xFEC2),
    ("/tahinitialarabic", 0xFEC3),
    ("/tahmedialarabic", 0xFEC4),
    ("/tchehfinalarabic", 0xFB7B),
    ("/tchehinitialarabic", 0xFB7C),
    ("/tchehmedialarabic", 0xFB7D),
    ("/tehfinalarabic", 0xFE96),
    ("/tehhahinitialarabic", 0xFCA2),
    ("/tehhahisolatedarabic", 0xFC0C),
    ("/tehinitialarabic", 0xFE97),
    ("/tehjeeminitialarabic", 0xFCA1),
    ("/tehjeemisolatedarabic", 0xFC0B),
    ("/tehmarbutafinalarabic", 0xFE94),
    ("/tehmedialarabic", 0xFE98),
    ("/tehmeeminitialarabic", 0xFCA4),
    ("/tehmeemisolatedarabic", 0xFC0E),
    ("/tehnoonfinalarabic", 0xFC73),
    ("/thalfinalarabic", 0xFEAC),
    ("/thehfinalarabic", 0xFE9A),
    ("/thehinitialarabic", 0xFE9B),
    ("/thehmedialarabic", 0xFE9C),
    ("/ttehfinalarabic", 0xFB67),
    ("/ttehinitialarabic", 0xFB68),
    ("/ttehmedialarabic", 0xFB69),
    ("/vehfinalarabic", 0xFB6B),
    ("/vehinitialarabic", 0xFB6C),
    ("/vehmedialarabic", 0xFB6D),
    ("/wawfinalarabic", 0xFEEE),
    ("/wawhamzaabovefinalarabic", 0xFE86),
    ("/yehbarreefinalarabic", 0xFBAF),
    ("/yehfinalarabic", 0xFEF2),
    ("/yehhamzaabovefinalarabic", 0xFE8A),
    ("/yehhamzaaboveinitialarabic", 0xFE8B),
    ("/yehhamzaabovemedialarabic", 0xFE8C),
    ("/yehinitialarabic", 0xFEF3),
    ("/yehmedialarabic", 0xFEF4),
    ("/yehmeeminitialarabic", 0xFCDD),
    ("/yehmeemisolatedarabic", 0xFC58),
    ("/yehnoonfinalarabic", 0xFC94),
    ("/zahfinalarabic", 0xFEC6),
    ("/zahinitialarabic", 0xFEC7),
    ("/zahmedialarabic", 0xFEC8),
    ("/zainfinalarabic", 0xFEB0),
    ("/zerowidthjoiner", 0xFEFF),
  ]
  let differences : Array[@pdflite.PdfEncodingDifference] = []
  let text_codes : Array[Int] = []
  let expected_codepoints : Array[Int] = []
  for index in 0..<entries.length() {
    let entry = entries[index]
    let code = index + 1
    differences.push(text_difference_for_test(entry.0, code))
    text_codes.push(code)
    expected_codepoints.push(entry.1)
  }
  let standard_font : @pdflite.PdfFont = PdfFontStandard(
    text_standard_font_data_for_test(
      PdfHelvetica,
      PdfCustomEncoding(PdfStandardEncoding, differences),
    ),
  )
  let extractor = standard_font.text_extractor()
  @test.assert_eq(
    try! extractor.codepoints_of_text(text_bytes_for_test(text_codes)),
    expected_codepoints,
  )
  @test.assert_eq(extractor.charcode_of_codepoint(0xFECA), Some(1))
  @test.assert_eq(extractor.charcode_of_codepoint(0xFEEA), Some(35))
  @test.assert_eq(extractor.charcode_of_codepoint(0xFEF3), Some(9))
  @test.assert_eq(extractor.charcode_of_codepoint(0xFEB4), Some(100))
  @test.assert_eq(extractor.charcode_of_codepoint(0xFEC8), Some(150))
  @test.assert_eq(extractor.charcode_of_codepoint(0xFEFF), Some(152))
}
