    ("/vtilde", 0x1E7D),
    ("/wacute", 0x1E83),
    ("/wdieresis", 0x1E85),
    ("/wdotaccent", 0x1E87),
    ("/wdotbelow", 0x1E89),
    ("/wgrave", 0x1E81),
    ("/wring", 0x1E98),
    ("/xdieresis", 0x1E8D),
    ("/xdotaccent", 0x1E8B),
    ("/ydotaccent", 0x1E8F),
    ("/ydotbelow", 0x1EF5),
    ("/ygrave", 0x1EF3),
    ("/yhookabove", 0x1EF7),
    ("/yring", 0x1E99),
    ("/ytilde", 0x1EF9),
    ("/zcircumflex", 0x1E91),
    ("/zdotbelow", 0x1E93),
    ("/zlinebelow", 0x1E95),
  ]
  let differences : Array[@pdflite.PdfEncodingDifference] = []
  let text_codes : Array[Int] = []
  let expected_codepoints : Array[Int] = []
  for index in 0..<entries.length() {
    let entry = entries[index]
    let code = index + 1
    differences.push(text_difference_for_test(entry.0, code))
    text_codes.push(code)
    expected_codepoints.push(entry.1)
  }
  let standard_font : @pdflite.PdfFont = PdfFontStandard(
    text_standard_font_data_for_test(
      PdfHelvetica,
      PdfCustomEncoding(PdfStandardEncoding, differences),
    ),
  )
  let extractor = standard_font.text_extractor()
  @test.assert_eq(
    try! extractor.codepoints_of_text(text_bytes_for_test(text_codes)),
    expected_codepoints,
  )
  @test.assert_eq(extractor.charcode_of_codepoint(0x1EAE), Some(1))
  @test.assert_eq(extractor.charcode_of_codepoint(0x1E00), Some(13))
  @test.assert_eq(extractor.charcode_of_codepoint(0x1E9B), Some(210))
  @test.assert_eq(extractor.charcode_of_codepoint(0x1E95), Some(246))
}
