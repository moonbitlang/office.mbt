import {
  "bobzhang/mbtexcel" @lib,
  "bobzhang/mbtexcel/batch",
  "bobzhang/mbtexcel/inspect",
  "bobzhang/mbtexcel/xlsx2html",
  "bobzhang/mbtexcel/xlsx" @xl,
  "moonbitlang/core/argparse",
  "moonbitlang/async",
  "moonbitlang/async/fs" @async/fs,
  "moonbitlang/async/os_error" @os_error,
  "moonbitlang/core/env",
  "moonbitlang/core/encoding/utf8" @encoding/utf8,
  "moonbitlang/core/string",
  "moonbitlang/core/json",
