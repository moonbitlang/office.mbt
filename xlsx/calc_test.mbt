  inspect(workbook.calc_cell_value("Sheet1", "A17"), content="#VALUE!")
  sheet.set_cell_formula("A18", "GESTEP(0,\"\")")
  inspect(workbook.calc_cell_value("Sheet1", "A18"), content="#VALUE!")
}

