  sheet.set_cell_formula("E2", "SQRTPI(0.2)")
  inspect(
    workbook.calc_cell_value("Sheet1", "E2"),
    content="0.7926654595212022",
  )
  sheet.set_cell_formula("E3", "SQRTPI(100)")
