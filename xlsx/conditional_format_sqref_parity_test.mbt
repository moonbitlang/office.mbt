///|
test "conditional format sqref parity: reversed/row/col refs" {
  let workbook = @xlsx.Workbook::new()
  let sheet = workbook.add_sheet("Sheet1")
  let opt1 = @xlsx.ConditionalFormatOptions::new("data_bar")
  opt1.set_criteria("=")
  opt1.set_min_type("num")
  opt1.set_max_type("num")
  opt1.set_min_value("-10")
  opt1.set_max_value("10")
  opt1.set_bar_border_color("#0000FF")
  opt1.set_bar_color("#638EC6")
  opt1.set_bar_only(true)
  opt1.set_bar_solid(true)
  opt1.set_stop_if_true(true)
  let opt2 = @xlsx.ConditionalFormatOptions::new("data_bar")
  opt2.set_criteria("=")
  opt2.set_min_type("min")
  opt2.set_max_type("max")
  opt2.set_bar_border_color("#0000FF")
  opt2.set_bar_color("#638EC6")
  opt2.set_bar_direction("rightToLeft")
  opt2.set_bar_only(true)
  opt2.set_bar_solid(false)
  opt2.set_stop_if_true(true)
  sheet.set_conditional_format("A2:A1,B:B,2:2", [opt1, opt2])
  let formats = sheet.get_conditional_formats()
  let got = formats.get("A2:A1 B1:B1048576 A2:XFD2").unwrap()
  inspect(got.length(), content="2")
  inspect(got[0].min_value, content="-10")
  inspect(got[1].bar_direction, content="rightToLeft")
}
