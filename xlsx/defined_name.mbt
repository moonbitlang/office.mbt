///|
pub struct DefinedName {
  name : String
  refers_to : String
  scope : String
  comment : String
} derive(Eq, Show)

///|
pub fn DefinedName::new(
  name : String,
  refers_to : String,
  scope? : String = "",
  comment? : String = "",
) -> DefinedName {
  let scope_value = if scope == "" { "Workbook" } else { scope }
  { name, refers_to, scope: scope_value, comment }
}

