///|
test "get_conditional_formats parity: criteria defaults + color scale values" {
  let workbook = Workbook::new()
  let sheet = workbook.add_sheet("Sheet1")
  let dup = ConditionalFormatOptions::new("duplicate")
  sheet.set_conditional_format("A1:A2", [dup])
  let uniq = ConditionalFormatOptions::new("unique")
  sheet.set_conditional_format("B1:B2", [uniq])
  let scale2 = ConditionalFormatOptions::new("2_color_scale")
  scale2.set_min_type("num")
  scale2.set_max_type("num")
  scale2.set_min_color("#FF0000")
  scale2.set_max_color("#0000FF")
  sheet.set_conditional_format("C1:C2", [scale2])
  let scale3 = ConditionalFormatOptions::new("3_color_scale")
  scale3.set_min_type("num")
  scale3.set_mid_type("num")
  scale3.set_max_type("num")
  scale3.set_min_value("-10")
  scale3.set_mid_value("50")
  scale3.set_max_value("10")
  scale3.set_min_color("#FF0000")
  scale3.set_mid_color("#00FF00")
  scale3.set_max_color("#0000FF")
  sheet.set_conditional_format("D1:D2", [scale3])
  let parsed = read(write(workbook))
  let formats = parsed.get_conditional_formats("Sheet1")
  let dup_opts = formats.get("A1:A2").unwrap()
  inspect(dup_opts[0].criteria, content="=")
  let uniq_opts = formats.get("B1:B2").unwrap()
  inspect(uniq_opts[0].criteria, content="=")
  let scale2_opts = formats.get("C1:C2").unwrap()
  inspect(scale2_opts[0].criteria, content="=")
  inspect(scale2_opts[0].min_value, content="")
  inspect(scale2_opts[0].max_value, content="")
  let scale3_opts = formats.get("D1:D2").unwrap()
  inspect(scale3_opts[0].criteria, content="=")
  inspect(scale3_opts[0].min_value, content="-10")
  inspect(scale3_opts[0].mid_value, content="50")
  inspect(scale3_opts[0].max_value, content="10")
}
